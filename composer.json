{
    "name": "trinavo/livewire-page-builder",
    "description": "A Laravel package for dynamic page building with Livewire",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Firas Abd Alrahman",
            "email": "doonfrs@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "livewire/livewire": "^3.6",
        "laravel/helpers": "^1.7",
        "blade-ui-kit/blade-heroicons": "^2.6",
        "blade-ui-kit/blade-icons": "^1.8"
    },
    "require-dev": {
        "laravel/framework": "^12.0",
        "laravel/pint": "^1.22",
        "larastan/larastan": "^3.7",
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Trinavo\\LivewirePageBuilder\\": "src/"
        },
        "files": [
            "src/Support/helpers.php",
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Trinavo\\LivewirePageBuilder\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Trinavo\\LivewirePageBuilder\\Providers\\PageBuilderServiceProvider"
            ],
            "aliases": {
                "PageBuilderVariables": "Trinavo\\LivewirePageBuilder\\Facades\\PageBuilderVariables",
                "ThemeEncryptionService": "Trinavo\\LivewirePageBuilder\\Facades\\ThemeEncryptionService"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
